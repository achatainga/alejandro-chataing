rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // notifications: public write, read allowed (admin reads via client with API key)
    match /notifications/{type}/items/{docId} {
      allow create: if true;
      allow read: if true;
      allow update, delete: if false;
    }

    // chat_sessions: write-only from client
    match /chat_sessions/{sessionId} {
      allow create, update: if true;
      allow read, delete: if false;
    }

    // config: traffic_state, gemini_rotation, gemini_model — read+write from client
    match /config/{configId} {
      allow read, write: if configId in ['traffic_state', 'gemini_rotation', 'gemini_model'];
    }
  }
}
