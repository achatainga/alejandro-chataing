rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // notifications: write-only from client, read only via Admin SDK
    match /notifications/{type}/items/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // chat_sessions: write-only from client (AI chat auto-save)
    match /chat_sessions/{sessionId} {
      allow create, update: if true;
      allow read, delete: if false;
    }

    // config/traffic_state + config/gemini_rotation: read+write from client
    match /config/{configId} {
      allow read, write: if configId in ['traffic_state', 'gemini_rotation'];
    }
  }
}
